# Lyralabs VM /opt/lyralabs/.env template.
#
# Copy this to /opt/lyralabs/.env on the VM and fill in. Same vars as the
# Cloud Run API plus REDIS_PASSWORD and WORKER_IMAGE (VM-specific).
#
# Security: this file holds DB credentials, encryption keys, LLM API keys,
# and the Redis password. `chmod 600 /opt/lyralabs/.env` after writing.

# --- VM-specific ---
# Pick a strong random password for Redis AUTH:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=

# Full image URL the worker container will pull. Same image lyralabs-app
# uses on Cloud Run. Find it via:
#   gcloud run services describe lyralabs-app --region=us-east1 \
#     --format='value(spec.template.spec.containers[0].image)'
# Example: us-east1-docker.pkg.dev/PROJECT/cloud-run-source-deploy/lyralabs-app/lyralabs-app:LATEST_SHA
WORKER_IMAGE=

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO
APP_BASE_URL=https://lyralabs-app-876710803394.us-east1.run.app
ADMIN_BASE_URL=https://lyralabs.vercel.app

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# --- Redis (worker connects via docker-compose service name) ---
# `redis` resolves to the redis container's internal IP via docker DNS.
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://default:${REDIS_PASSWORD}@redis:6379/0

# --- Crypto (MUST match lyralabs-app exactly, otherwise can't decrypt
#              tenant Slack bot tokens) ---
MASTER_ENCRYPTION_KEY=
ADMIN_JWT_SECRET=
ADMIN_JWT_ISSUER=lyralabs-admin

# --- LLM (MVP: all-Qwen) ---
LLM_PRIMARY_MODEL=dashscope/qwen-max
LLM_CHEAP_MODEL=dashscope/qwen-turbo
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Slack (signing secret only, worker doesn't validate webhooks but
#            some imports reference it) ---
SLACK_SIGNING_SECRET=

# --- Optional: tools (fill in when each integration goes live) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GHL_CLIENT_ID=
# GHL_CLIENT_SECRET=
