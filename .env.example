# Lyralabs — environment template
# Copy to `.env` and fill in. Cloud / hosted-service setup notes live in
# README.md and docs/DEPLOY.md, not here.

# === App ======================================================================
APP_ENV=development
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
ADMIN_BASE_URL=http://localhost:5173

# === Storage ==================================================================
# Postgres: asyncpg for runtime, psycopg for alembic. Same host/user/password,
# different driver + (for Supabase pooler) different port.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Redis. Local dev uses three logical DBs; managed services (Upstash etc.)
# typically expose only DB 0 — point all three at /0, prefixed keys avoid clash.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Vector DB (only required when semantic memory / RAG is enabled).
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# === Crypto ===================================================================
# Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JWT secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
MASTER_ENCRYPTION_KEY=
ADMIN_JWT_SECRET=
ADMIN_JWT_ISSUER=lyralabs-admin

# === LLM providers ============================================================
# Model strings: <provider>/<model>. See packages/lyra_core/common/llm.py
# for the full list of supported providers and example model names.
#
# MVP default is all-Qwen (single API key, cheapest). Switch to anthropic/* +
# gemini/* + openai/* once those keys are filled in for higher-quality models.
# Embeddings: LiteLLM lacks a Qwen embedding provider (BerriAI/litellm#25690),
# so LLM_EMBEDDING_MODEL stays on OpenAI. It's unused until RAG is wired up.
LLM_PRIMARY_MODEL=dashscope/qwen-max
LLM_CHEAP_MODEL=dashscope/qwen-turbo
LLM_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Alibaba Qwen via DashScope. Use the China endpoint
# (https://dashscope.aliyuncs.com/compatible-mode/v1) if your key is mainland.
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# DeepSeek (V3 = deepseek-chat, R1 = deepseek-reasoner).
DEEPSEEK_API_KEY=

# === Channels =================================================================
# Slack — required for the bot to install into a workspace.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_SCOPES=app_mentions:read,channels:history,channels:read,chat:write,commands,files:write,groups:history,im:history,im:read,im:write,users:read
SLACK_USER_SCOPES=
SLACK_INSTALL_REDIRECT_URL=http://localhost:8000/oauth/slack/callback

# Microsoft Teams (phase 2 — leave blank for MVP).
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# === Tool integrations ========================================================
# Google Workspace OAuth (Drive, Docs, Sheets, Calendar, Slides).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/documents,https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/presentations

# GoHighLevel OAuth.
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=http://localhost:8000/oauth/ghl/callback
GHL_SCOPES=contacts.readonly contacts.write opportunities.readonly opportunities.write conversations.readonly conversations.write conversations/message.write calendars.readonly calendars.write workflows.readonly locations.readonly users.readonly

# === Billing (Stripe) =========================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_TRIAL_CREDIT_USD=100
