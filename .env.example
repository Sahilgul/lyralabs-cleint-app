# Lyralabs — environment template
# Copy to `.env` and fill in. Cloud / hosted-service setup notes live in
# README.md and docs/DEPLOY.md, not here.

# === App ======================================================================
APP_ENV=development
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
ADMIN_BASE_URL=http://localhost:5173

# === Storage ==================================================================
# Postgres: asyncpg for runtime, psycopg for alembic. Same host/user/password,
# different driver + (for Supabase pooler) different port.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Redis.
#   Local dev (docker-compose Redis): use 3 logical DBs (/0 general, /1 broker, /2 results).
#   Cloud (Upstash free tier supports only DB 0): point ALL THREE at /0 — Celery's
#   prefixed keys (`celery-task-meta-*`, `_kombu.*`) avoid collisions with general use.
#   See infra/cloud-run/README.md for the exact cloud values.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Vector DB (only required when semantic memory / RAG is enabled).
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# === Crypto ===================================================================
# Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# JWT secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
MASTER_ENCRYPTION_KEY=
ADMIN_JWT_SECRET=
ADMIN_JWT_ISSUER=lyralabs-admin

# === LLM providers ============================================================
# Model strings follow LiteLLM format: <litellm_prefix>/<model_name>.
# See packages/lyra_core/llm/catalog.py for the full provider + model catalog.

# ---------------------------------------------------------------------------
# Per-role model assignments  (used by chat(tier=ModelTier.*))
# ---------------------------------------------------------------------------
#   PRIMARY  — agent_node orchestrator: plans, decides tools, reasons deeply.
#              Default: DeepSeek V4-Pro (strong world-knowledge + MoE reasoning).
#   CRITIC   — critic_node: writes the final user-facing message posted to Slack.
#              Default: MiniMax M2.7 (3.3 s avg, 100% voice score in eval — 1.8 s
#              faster than DeepSeek Pro for a task that is summarisation, not reasoning).
#   CHEAP    — fast helper calls (tool pre-routing filter, cheap-pass checks, etc.)
#              Default: DeepSeek V4-Flash.
#   EMBEDDING — vector search / semantic memory.
LLM_PRIMARY_MODEL=deepseek/deepseek-v4-pro
LLM_CRITIC_MODEL=openai/MiniMax-M2.7
LLM_CHEAP_MODEL=deepseek/deepseek-v4-flash
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Three-tier resilience chain  (used by chat_with_fallback(quality=...))
# ---------------------------------------------------------------------------
# If the primary provider returns a timeout / rate-limit / 5xx, the agent
# automatically falls through to the next provider in the chain, then the
# next. A provider is silently skipped if its API key is missing, so the
# chain shortens gracefully — only DEEPSEEK_API_KEY is required to start.
#
#   Pro   — agent_node reasoning turns, multi-step tool planning.
#   Flash — cheap pre-routing filters, single-shot helper calls.
#
# Model IDs must be valid LiteLLM identifiers listed in catalog.py.
# MiniMax and Kimi use the "openai/" prefix (OpenAI-compat endpoint).

LLM_PRIMARY_PRO=deepseek/deepseek-v4-pro        # DeepSeek V4-Pro  · $0.435/M in · $0.87/M out
LLM_PRIMARY_FLASH=deepseek/deepseek-v4-flash    # DeepSeek V4-Flash · $0.14/M in  · $0.28/M out

LLM_SECONDARY_PRO=openai/MiniMax-M2.7           # MiniMax M2.7      · $0.30/M in  · $1.20/M out
LLM_SECONDARY_FLASH=openai/MiniMax-M2.5         # MiniMax M2.5      · $0.30/M in  · $1.20/M out

LLM_TERTIARY_PRO=openai/kimi-k2.6               # Kimi K2.6         · $0.95/M in  · $4.00/M out
LLM_TERTIARY_FLASH=openai/kimi-k2.5             # Kimi K2.5         · $0.60/M in  · $3.00/M out

# ---------------------------------------------------------------------------
# Provider API keys
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Alibaba Qwen via DashScope. Use the China endpoint
# (https://dashscope.aliyuncs.com/compatible-mode/v1) if your key is mainland.
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# DeepSeek — Primary provider. Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# MiniMax — Secondary provider. Get key at: https://www.minimax.io/platform
MINIMAX_API_KEY=

# Kimi (Moonshot AI) — Tertiary provider. Get key at: https://platform.moonshot.ai
KIMI_API_KEY=

# === Channels =================================================================
# Slack — required for the bot to install into a workspace.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Bot scopes -- the tools layer relies on these:
#   * channels:history / groups:history / im:history / mpim:history
#       -> slack.conversations.history + .replies (read older messages
#          across public channels, private channels, DMs, and group DMs).
#   * users:read / users:read.email
#       -> slack.users.info / slack.users.list (resolve names <-> ids,
#          fetch profile + email).
#   * canvases:read / canvases:write
#       -> slack.canvas.create (write tool, gated through approval).
SLACK_SCOPES=app_mentions:read,channels:history,channels:read,chat:write,commands,files:write,groups:history,im:history,im:read,im:write,mpim:history,users:read,users:read.email,canvases:read,canvases:write
# User scopes -- only `search.messages` requires a user token (Slack
# disallows bot tokens for search). If you don't need cross-channel
# search inside ARLO, leave SLACK_USER_SCOPES empty and the search tool
# will degrade with a "missing permission, reauthorize" error rather
# than crashing.
SLACK_USER_SCOPES=search:read.public,search:read.private,search:read.mpim,search:read.im,search:read.files
# App-Level Token (xapp-) used by Socket Mode. Required ONLY when running
# the Socket Mode runner (apps/worker/socket_runner.py); the HTTPS webhook
# at /slack/events on Cloud Run does not need this. Generate at:
#   api.slack.com/apps -> your app -> Basic Information -> App-Level Tokens
# Scope: connections:write (REQUIRED for Socket Mode).
SLACK_APP_TOKEN=
SLACK_INSTALL_REDIRECT_URL=http://localhost:8000/oauth/slack/callback

# Microsoft Teams (phase 2 — leave blank for MVP).
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# === Tool integrations ========================================================
# Google Workspace OAuth (Drive, Docs, Sheets, Calendar, Slides).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/documents,https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/presentations

# GoHighLevel OAuth.
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=http://localhost:8000/oauth/ghl/callback
GHL_SCOPES=contacts.readonly contacts.write opportunities.readonly opportunities.write conversations.readonly conversations.write conversations/message.write calendars.readonly calendars.write workflows.readonly locations.readonly users.readonly

# GoHighLevel Eval credentials (OPTIONAL — only needed for tests/eval/test_arlo_ghl_live.py).
# These are NOT used in production. The live eval fetches real GHL tool schemas and
# executes real read calls so you can compare how each model handles actual CRM data.
#
# How to get these:
#   1. Go to your GHL sub-account → Settings → Business Info → Private Integrations
#   2. Create a Private Integration with scopes:
#        contacts.readonly, opportunities.readonly, conversations.readonly, calendars.readonly
#      (read-only is enough — write calls are captured as plans and not executed)
#   3. Copy the token (starts with "pit-") and your Location ID.
GHL_EVAL_TOKEN=
GHL_EVAL_LOCATION_ID=

# === Billing (Stripe) =========================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_TRIAL_CREDIT_USD=100
